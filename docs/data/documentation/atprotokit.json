{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/atprotokit"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"ATProtoKit is a Swift package designed for building applications and interacting with the AT Protocol (short for “Authenticated Transfer Protocol”) and Bluesky. It provides all necessary client-side implementations to seamlessly interact with the AT Protocol, and fully integrates the various features of Bluesky. The library supports a wide range of functionalities, from identifier validations (including NSIDs, DIDs, Record Keys, AT-URIs, and more) to data stream viewing, offering a robust toolset for developers at all skill levels."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"ATProtoKit aims to be easy enough to use for novice developers, while also being extendable and advanced enough for more experienced developers."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Below is a very quick example to run the project:"}]},{"code":["import ATProtoKit","","let config = ATProtocolConfiguration()","","Task {","    print(\"Starting application...\")","","    do {","        try await config.authenticate(with: \"example.bsky.social\", password: \"hunter2\")","","        let atProto = await ATProtoKit(sessionConfiguration: config)","        let atProtoBluesky = ATProtoBluesky(atProtoKitInstance: atProto)","","        let postResult = try await atProtoBluesky.createPostRecord(text: \"Hello Bluesky!\")","","        print(postResult)","    } catch {","        print(\"Error: \\(error)\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"ATProtoKit is fully open source under the "},{"identifier":"https:\/\/github.com\/MasterJ93\/ATProtoKit\/blob\/main\/LICENSE.md","type":"reference","isActive":true},{"type":"text","text":". You can take a look at it and make contributions to it "},{"identifier":"https:\/\/github.com\/MasterJ93\/ATProtoKit","type":"reference","isActive":true},{"type":"text","text":". Some of the documentation has been copied or adapted from "},{"identifier":"https:\/\/github.com\/bluesky-social\/atproto","type":"reference","isActive":true},{"type":"text","text":". ATProtoKit adopts the "},{"identifier":"https:\/\/github.com\/MasterJ93\/ATProtoKit\/blob\/main\/ATProtoLicense\/ATPROTO-LICENSE.txt","type":"reference","isActive":true},{"type":"text","text":" from their repo."}]},{"anchor":"Whats-New-in-ATProtoKit","type":"heading","text":"What’s New in ATProtoKit","level":2},{"type":"links","style":"detailedGrid","items":["doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/SessionDebuggableArticle","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/SessionConfigurationArticle","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/0210AuthFlowChange","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/getRecordTutorial"]}]}],"hierarchy":{"paths":[[]]},"abstract":[{"type":"text","text":"Develop and manage client and server-side applications for the AT Protocol and Bluesky."}],"identifier":{"url":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit","interfaceLanguage":"swift"},"metadata":{"role":"collection","title":"ATProtoKit","externalID":"ATProtoKit","images":[{"identifier":"atprotokit_icon.png","type":"icon"}],"symbolKind":"module","roleHeading":"Framework","modules":[{"name":"ATProtoKit"}],"color":{"standardColorIdentifier":"blue"}},"topicSections":[{"identifiers":["doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/Getting-Started-with-ATProtoKit","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoAdmin","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBlueskyChat"],"title":"