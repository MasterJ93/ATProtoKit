{"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"seeAlsoSections":[{"identifiers":["doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoAdmin","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBlueskyChat"],"title":"Essentials","generated":true,"anchor":"Essentials"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/atprotokit\/getting-started-with-atprotokit"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"inlineContent":[{"type":"text","text":"ATProtoKit is designed to make it easy for you to interact with the AT Protocol and other services built on of the technology, such as Bluesky."}],"type":"paragraph"},{"text":"Creating a session","type":"heading","anchor":"Creating-a-session","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to log in, you need to create a session. To get started, create a new "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration"},{"type":"text","text":" instance:"}]},{"type":"codeListing","syntax":"swift","code":["let config = ATProtocolConfiguration()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can create a session with the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration\/authenticate(with:password:)"},{"type":"text","text":" method:"}]},{"type":"codeListing","syntax":"swift","code":["Task {","    try await config.authenticate(with: \"lucy.bsky.social\", password: \"hunter2\")","}"]},{"type":"aside","content":[{"inlineContent":[{"text":"Do not use the password you typically use for signing into Bluesky: only use a specific App Password that’s in use for this instance of ATProtoKit only. To generate an App Password, go to the Bluesky website, then go to Settings > Privacy & Security > App Passwords and follow the instructions.","type":"text"}],"type":"paragraph"}],"style":"important","name":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a "},{"type":"codeVoice","code":"do-catch"},{"type":"text","text":" block to create the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/UserSession"},{"type":"text","text":" object (if the session was successfully created) or handle the error (if an error occured):"}]},{"type":"codeListing","syntax":"swift","code":["let config = ATProtocolConfiguration()","","Task {","    do {","        try await config.authenticate(with: \"lucy.bsky.social\", password: \"hunter2\")","","        \/\/ Handle the success.","    } catch {","        \/\/ Handle the error.","    }","}"]},{"type":"aside","content":[{"inlineContent":[{"text":"If you’ve enabled Two-Factor Authentication (via email), ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration\/authenticate(with:password:)"},{"text":" waits for the code after the server returns ","type":"text"},{"code":"AuthFactorTokenRequired","type":"codeVoice"},{"text":". Check your inbox for the code, then pass it to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/SessionConfiguration\/receiveCodeFromUser(_:)"},{"text":" from your UI or command-line input handler.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/UserSession","type":"reference"},{"text":" will contain, among other things, the access and refresh tokens. ATProtoKit abstracts this away for you so you don’t need to add it every time you use a method that requires an active session.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can then create an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit"},{"text":" instance, where you can insert the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration","type":"reference"},{"text":" object in the ","type":"text"},{"code":"sessionConfiguration","type":"codeVoice"},{"text":" parameter:","type":"text"}]},{"code":["Task {","    let atProto = await ATProtoKit(sessionConfiguration: config)","}"],"syntax":"swift","type":"codeListing"},{"text":"Creating a post","level":3,"anchor":"Creating-a-post","type":"heading"},{"inlineContent":[{"type":"text","text":"To create a post, first create an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky"},{"text":" instance, with the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit"},{"text":" instance as the parameter:","type":"text"}],"type":"paragraph"},{"code":["let atProtoBluesky = ATProtoBluesky(atProtoKitInstance: atProto)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Then use the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky\/createPostRecord(text:inlineFacets:locales:replyTo:embed:labels:tags:creationDate:replyControls:embeddingRules:recordKey:shouldValidate:swapCommit:)"},{"text":" method. While this method is extremely extensive, we’re only going to focus on the ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" parameter.","type":"text"}],"type":"paragraph"},{"code":["let postResult = try await atProtoBluesky.createPostRecord(text: \"Hello Bluesky!\")","print(postResult)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You should see the post in your Bluesky account once you run this code. When the method successfully completes, you’ll receive a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Repository\/StrongReference","type":"reference"},{"text":" object that contains the URI of the record (","type":"text"},{"isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Repository\/StrongReference\/recordURI","type":"reference"},{"text":") and the content identifier hash of the record (","type":"text"},{"isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Repository\/StrongReference\/recordCID","type":"reference"},{"text":").","type":"text"}]},{"level":3,"type":"heading","text":"View Your Own Posts","anchor":"View-Your-Own-Posts"},{"type":"paragraph","inlineContent":[{"text":"To view your own posts, you can use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit\/getAuthorFeed(by:limit:cursor:postFilter:shouldIncludePins:)","type":"reference"},{"text":" and use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/UserSession\/handle","type":"reference"},{"text":" in the first argument:","type":"text"}]},{"code":["do {","    guard let session = try await atProto.getUserSession() else { return }","    let myFeed = try await atProto.getAuthorFeed(by: session.handle)","    print(\"Feed: \\(myFeed)\")","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, it will grab the first 50 posts from you, including replies, and without the pinned post. However, you can tweak that with the "},{"code":"limit","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"postFilter"},{"text":", and ","type":"text"},{"code":"shouldIncludePins","type":"codeVoice"},{"text":" arguments. You can also poll more posts if a singular call reaches its limit by using ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/AppBskyLexicon\/Feed\/GetAuthorFeedOutput\/cursor","type":"reference"},{"text":" with the next API call:","type":"text"}]},{"code":["let myFeed = try await atProto.getAuthorFeed(","    by: \"lucy.bsky.social\",","    limit: 100",")","","print(\"Feed (first 100 posts): \\(myFeed)\")","","\/\/ To get the next 100 posts, call the method again,","\/\/ but attach the `cursor` as an argument.","","let myFeedExtended = try await atProto.getAuthorFeed(","    by: \"lucy.bsky.social\",","    limit: 100,","    cursor: myFeed.cursor",")","","print(\"Feed (next 100 posts): \\(myFeedExtended)\")"],"syntax":"swift","type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/ATProtoKit\/documentation\/ATProtoKit"]]},"abstract":[{"type":"text","text":"Sign in with a Bluesky account, send a post, and view the account’s posts."}],"identifier":{"url":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/Getting-Started-with-ATProtoKit","interfaceLanguage":"swift"},"metadata":{"images":[{"type":"icon","identifier":"bluesky_logo.png"}],"modules":[{"name":"ATProtoKit"}],"title":"Getting Started with ATProtoKit","roleHeading":"Article","role":"article","color":{"standardColorIdentifier":"blue"}},"references":{"doc://ATProtoKit/documentation/ATProtoKit/ATProtoKit":{"title":"ATProtoKit","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ATProtoKit","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit","url":"\/documentation\/atprotokit\/atprotokit","abstract":[{"text":"The base class that handles the main functionality of the ","type":"text"},{"code":"ATProtoKit","type":"codeVoice"},{"text":" API library.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"AT