{"kind":"article","hierarchy":{"paths":[["doc:\/\/ATProtoKit\/documentation\/ATProtoKit"]]},"identifier":{"url":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/Getting-Started-with-ATProtoKit","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Sign in with a Bluesky account, send a post, and view the account’s posts."}],"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoAdmin","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBlueskyChat"],"generated":true,"anchor":"Essentials"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"ATProtoKit is designed to make it easy for you to interact with the AT Protocol and other services built on of the technology, such as Bluesky."}]},{"level":3,"type":"heading","text":"Creating a session","anchor":"Creating-a-session"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to log in, you need to create a session. To get started, create a new "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration"},{"type":"text","text":" instance:"}]},{"type":"codeListing","syntax":"swift","code":["let config = ATProtocolConfiguration()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then, you can create a session with the "},{"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration\/authenticate(with:password:)","isActive":true},{"type":"text","text":" method:"}]},{"type":"codeListing","syntax":"swift","code":["Task {","    try await config.authenticate(with: \"lucy.bsky.social\", password: \"hunter2\")","}"]},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"Do not use the password you typically use for signing into Bluesky: only use a specific App Password that’s in use for this instance of ATProtoKit only. To generate an App Password, go to the Bluesky website, then go to Settings > Privacy & Security > App Passwords and follow the instructions.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"You can use a ","type":"text"},{"code":"do-catch","type":"codeVoice"},{"text":" block to create the ","type":"text"},{"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/UserSession","isActive":true},{"text":" object (if the session was successfully created) or handle the error (if an error occured):","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let config = ATProtocolConfiguration()","","Task {","    do {","        try await config.authenticate(with: \"lucy.bsky.social\", password: \"hunter2\")","","        \/\/ Handle the success.","    } catch {","        \/\/ Handle the error.","    }","}"]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"If you’ve enabled Two-Factor Authentication (via email), you may see an "},{"type":"codeVoice","code":"AuthFactorTokenRequired"},{"type":"text","text":" error. In that case, check your inbox for a code, then call "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration\/authenticate(with:password:)"},{"type":"text","text":" again, but put in the code for the "},{"type":"codeVoice","code":"authenticationFactorToken"},{"type":"text","text":" parameter."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/UserSession","isActive":true},{"text":" will contain, among other things, the access and refresh tokens. ATProtoKit abstracts this away for you so you don’t need to add it every time you use a method that requires an active session.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can then create an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit"},{"text":" instance, where you can insert the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration"},{"text":" object in the ","type":"text"},{"code":"sessionConfiguration","type":"codeVoice"},{"text":" parameter:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Task {","    let atProto = await ATProtoKit(sessionConfiguration: config)","}"]},{"level":3,"type":"heading","text":"Creating a post","anchor":"Creating-a-post"},{"type":"paragraph","inlineContent":[{"text":"To create a post, first create an ","type":"text"},{"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky","type":"reference","isActive":true},{"text":" instance, with the ","type":"text"},{"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit","type":"reference","isActive":true},{"text":" instance as the parameter:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let atProtoBluesky = ATProtoBluesky(atProtoKitInstance: atProto)"]},{"type":"paragraph","inlineContent":[{"text":"Then use the ","type":"text"},{"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky\/createPostRecord(text:inlineFacets:locales:replyTo:embed:labels:tags:creationDate:replyControls:embeddingRules:recordKey:shouldValidate:swapCommit:)","type":"reference","isActive":true},{"text":" method. While this method is extremely extensive, we’re only going to focus on the ","type":"text"},{"type":"codeVoice","code":"text"},{"text":" parameter.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let postResult = try await atProtoBluesky.createPostRecord(text: \"Hello Bluesky!\")","print(postResult)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should see the post in your Bluesky account once you run this code. When the method successfully completes, you’ll receive a "},{"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Repository\/StrongReference","isActive":true,"type":"reference"},{"type":"text","text":" object that contains the URI of the record ("},{"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Repository\/StrongReference\/recordURI","isActive":true,"type":"reference"},{"type":"text","text":") and the content identifier hash of the record ("},{"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Repository\/StrongReference\/recordCID","isActive":true,"type":"reference"},{"type":"text","text":")."}]},{"level":3,"type":"heading","text":"View Your Own Posts","anchor":"View-Your-Own-Posts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To view your own posts, you can use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoKit\/getAuthorFeed(by:limit:cursor:postFilter:shouldIncludePins:)"},{"type":"text","text":" and use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/UserSession\/handle"},{"type":"text","text":" in the first argument:"}]},{"type":"codeListing","syntax":"swift","code":["do {","    guard let session = atProto.session else { return }","    let myFeed = try await atProto.getAuthorFeed(by: session.handle)","    print(\"Feed: \\(myFeed)\")","} catch {","    throw error","}"]},{"type":"paragraph","inlineContent":[{"text":"By default, it will grab the first 50 posts from you, including replies, and without the pinned post. However, you can tweak that with the ","type":"text"},{"code":"limit","type":"codeVoice"},{"text":", ","type":"text"},{"code":"postFilter","type":"codeVoice"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"shouldIncludePins"},{"text":" arguments. You can also poll more posts if a singular call reaches its limit by using ","type":"text"},{"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/AppBskyLexicon\/Feed\/GetAuthorFeedOutput\/cursor","isActive":true},{"text":" with the next API call:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let myFeed = try await atProto.getAuthorFeed(","    by: \"lucy.bsky.social\",","    limit: 100",")","","print(\"Feed (first 100 posts): \\(myFeed)\")","","\/\/ To get the next 100 posts, call the method again,","\/\/ but attach the `cursor` as an argument.","","let myFeedExtended = try await atProto.getAuthorFeed(","    by: \"lucy.bsky.social\",","    limit: 100,","    cursor: myFeed.cursor",")","","print(\"Feed (next 100 posts): \\(myFeedExtended)\")"]}]}],"metadata":{"modules":[{"name":"ATProtoKit"}],"roleHeading":"Article","color":{"standardColorIdentifier":"blue"},"role":"article","title":"Getting Started with ATProtoKit","images":[{"type":"icon","identifier":"bluesky_logo.png"}]},"variants":[{"paths":["\/documentation\/atprotokit\/getting-started-with-atprotokit"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"bluesky_logo.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/ATProtoKit\/bluesky_logo.png"}],"identifier":"bluesky_logo.png","alt":null},"doc://ATProtoKit/documentation/ATProtoKit/UserSession/handle":{"kind":"symbol","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/UserSession\/handle","title":"handle","abstract":[{"text":"The user’s handle within the AT Protocol.","type":"text"}],"type":"topic","url":"\/documentation\/atprotokit\/usersession\/handle","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"handle"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifi