ameters"},{"kind":"content","content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A ftuple, which contains the feed’s AT URI, as well as the posts contained in said feed."}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"content":[{"type":"paragraph","inlineContent":[{"text":"This deals with trending topics, which is under the","type":"text"},{"text":" ","type":"text"},{"code":"app.bsky.unspecced.*","type":"codeVoice"},{"text":" Namespaced Identifier (NSID). Lexicons under this can change at any time","type":"text"},{"text":" ","type":"text"},{"text":"without warning. It may also be removed at any time without warning.. ATProtoKit will try to keep up","type":"text"},{"text":" ","type":"text"},{"text":"with those changes, but this is not a guarantee.","type":"text"}]}],"style":"important","type":"aside","name":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before calling this method, be sure to use the methods provided to get the link of the"},{"type":"text","text":" "},{"type":"text","text":"trending feed. The method will then parse the link into an AT URI to find the feed for viewing."}]},{"syntax":"swift","code":["do {","    let atProtoKit = await ATProtoKit(sessionConfiguration: config)","    let atProtoBluesky = ATProtoBluesky(atProtoKitInstance: atProtoKit)","","    \/\/ Get the link of the trending topic.","    let trendLink = try await atProtoKit.getTrends().trends[0].link","    let trendingFeed = try await atProtoBluesky.viewTrendingFeed(trendLink)","    print(\"Trending Feed: \\(trendingFeed)\")","} catch {","    throw error","}"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The link will look something like this: "},{"code":"\/profile\/trending.bsky.app\/feed\/[feedID]","type":"codeVoice"},{"type":"text","text":"."}]}],"style":"note","