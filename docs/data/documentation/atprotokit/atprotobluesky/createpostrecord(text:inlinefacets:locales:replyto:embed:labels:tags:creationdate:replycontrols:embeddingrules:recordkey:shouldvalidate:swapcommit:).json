ay of tags for the post record. Optional. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"name":"creationDate","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The date of the post record. Defaults to "},{"type":"codeVoice","code":"Date.now"},{"type":"text","text":"."}]}]},{"name":"replyControls","content":[{"inlineContent":[{"type":"text","text":"An array of rules to control who can reply to the post. Optional."},{"type":"text","text":" "},{"type":"text","text":"Defaults to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":". When provided, a threadgate record is created for the post."}],"type":"paragraph"}]},{"name":"embeddingRules","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of rules to control embedding of the post. Optional."},{"type":"text","text":" "},{"type":"text","text":"Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". When provided, a postgate record is created for the post."}]}]},{"name":"recordKey","content":[{"inlineContent":[{"type":"text","text":"The record key of the collection. Optional. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"shouldValidate","content":[{"inlineContent":[{"type":"text","text":"Indicates whether the record should be validated. Optional."},{"type":"text","text":" "},{"type":"text","text":"Defaults to "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"swapCommit","content":[{"type":"paragraph","inlineContent":[{"text":"Swaps out an operation based on the CID. Optional. Defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}]}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A strong reference, which contains the newly-created record’s URI and CID hash."}]}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This can be used instead of creating your own method if you wish not to do so."}]},{"anchor":"Creating-a-Post","level":1,"type":"heading","text":"Creating a Post"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After you authenticate into Bluesky, you can create a post by using the "},{"type":"codeVoice","code":"text"},{"type":"text","text":" argument:"}]},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Just tried out the new coffee shop in town ☕️ — highly recommend the cold brew!\"","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your post is longer than 300 characters, the method will only take the first 300"},{"type":"text","text":" "},{"type":"text","text":"characters, discarding the rest."}]},{"type":"paragraph","inlineContent":[{"text":"Bluesky will automatically set the language of the post to English, but if you need to","type":"text"},{"text":" ","type":"text"},{"text":"manually set it, you can use the ","type":"text"},{"type":"codeVoice","code":"locales"},{"text":" argument:","type":"text"}]},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Première promenade d'automne 🍂. Les couleurs sont magnifiques cette année!\",","        locales: [Locale(identifier: \"fr_FR\")]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can add up to three locales at once; only the first three items will be added as this"},{"type":"text","text":" "},{"type":"text","text":"is the limit mandated by Bluesky."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"createPostRecord()"},{"text":" will automatically look for URLs, hashtags, and @mentions for you.","type":"text"},{"text":" ","type":"text"},{"text":"However, if you would like to add inline link facets to your account, you can use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"inlineFacets"},{"text":" parameter:","type":"text"}]},{"code":["do {","    let inlineFacet = (URL(string: \"https:\/\/www.loc.gov\/resource\/pga.05046\/\"), 57, 72)","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Where's that weird photo of a cat when you need one?\\n\\nAh: here it is!\",","        inlineFacets: [inlineFacet]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"startPostion","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"endPostion","type":"codeVoice"},{"text":" must be UTF-8 values.","type":"text"}],"type":"paragraph"}]},{"anchor":"Adding-Embedded-Content","level":1,"type":"heading","text":"Adding Embedded Content"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can embed various kinds of content in your post, from media to external links,"},{"type":"text","text":" "},{"type":"text","text":"to other records."}]},{"anchor":"Images","level":2,"type":"heading","text":"Images"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoTools\/ImageQuery"},{"type":"text","text":" to add details to the image, such as"},{"type":"text","text":" "},{"type":"text","text":"alt text, then attach it to the post record."}]},{"code":["do {","    let image = ATProtoTools.ImageQuery(","        imageData: Data(contentsOf: \"\/path\/to\/file\/cat.jpg\"),","        fileName: \"cat.jpg\",","        altText: \"A cat looking annoyed, wearing a hat.\"","    )","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"I don't think my cat likes her new hat... 🙃\",","        embed: .images(","            images: [image]","        )","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Up to four images can be attached to a post. All images need to be a .jpg format."}]},{"anchor":"Videos","level":2,"type":"heading","text":"Videos"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Similar to images, you can add videos to a post."}]},{"code":["let videoURL = URL(string: \"\/path\/to\/file\/beach.mp4\")","","do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"The waves on the beach are looking as beautiful as ever.\",","        embed: .video(video: Data(contentsOf: videoFileURL))","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only one video can be added to a post, can be 100 MB or less, and must use the .mp4 format."},{"type":"text","text":" "},{"type":"text","text":"You can upload up to 25 videos per day and the 25 videos can’t exceed a total of 500 MB"},{"type":"text","text":" "},{"type":"text","text":"for the day."}]},{"style":"tip","name":"Tip","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Bluesky allows you to upload GIFs the same way, as it considers it to be a special kind","type":"text"},{"text":" ","type":"text"},{"text":"of video.. The only difference with a GIF is the lack a player scrubber. The same restrictions","type":"text"},{"text":" ","type":"text"},{"text":"with respect to videos apply to uploaded GIFs.","type":"text"}]}]},{"anchor":"External-Links","level":2,"type":"heading","text":"External Links"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can attach a website card to the post."}]},{"code":["Task {","    print(\"Starting application...\")","","    do {","        try await config.authenticate(with: \"example.bsky.social\", password: \"hunter2\")","","        let externalLinkBuilder = ExternalLinkBuilder()","","        guard let link = URL(string: \"https:\/\/www.youtube.com\/watch?v=dQw4w9WgXcQ\") else { return }","        let metadata = try await linkBuilder.grabMetadata(from: link)","","        let atProto = await ATProtoKit(sessionConfiguration: config)","        let atProtoBluesky = ATProtoBluesky(atProtoKitInstance: atProto)","","        let postResult = try await atProtoBluesky.createPostRecord(","            text: \"Really glad to hear his talk in person!\",","            embed: .external(","                url: metadata.url,","                title: metadata.title,","                description: metadata.description ?? \"No description given.\",","                thumbnailURL: metadata.thumbnailURL","            )","        )","","        print(\"Post Result: \\(postResult)\")","    } catch {","        throw error","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If there are any links in the post’s text, the method will not convert it into a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"website card; you will need to manually achieve this."}]},{"anchor":"Creating-a-Quote-Post","level":1,"type":"heading","text":"Creating a Quote Post"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Quote posts are also embeds: you simply need to embed the record’s strong reference to it."}]},{"code":["do {","    let strongReference = ComAtprotoLexicon.Repository.StrongReference(recordURI: record.uri, cidHash: record.cid)","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Me whenever I look at my email:\",","        embed: .record(strongReference: strongReference)","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only one record can be embedded. This isn’t limited to post records, though: you can embed"},{"type":"text","text":" "},{"type":"text","text":"any Bluesky-related record that you wish."}]},{"anchor":"Creating-a-Reply","level":1,"type":"heading","text":"Creating a Reply"},{"type":"paragraph","inlineContent":[{"text":"To create a reply, pass the reply reference of the post’s reply reference to the post record.","type":"text"}]},{"code":["do {","    let replyReference = try await ATProtoTools().createReplyReference(","        from: parentPost,","        session: session","    )","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"I also like pancakes.\",","        replyTo: replyReference","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to create a thread of posts, use"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoTools\/createReplyReference(from:session:)","isActive":true},{"type":"text","text":" to create the reply reference and"},{"type":"text","text":" "},{"type":"text","text":"pass that over to "},{"type":"codeVoice","code":"replyTo"},{"type":"text","text":":"}]},{"code":["do {","    let threadPost = try await atProtoBluesky.createPostRecord(","        text: \"I like waffles.\"","    )","","    print(\"Replying...\")","","    let firstReplyReference = try await ATProtoTools().createReplyReference(from: threadPost, session: session)","","    let threadPost2 = try await atProtoBluesky.createPostRecord(","        text: \"I also like pancakes.\",","        replyTo: firstReplyReference","    )","","    print(\"Second reply...\")","","    let secondReplyReference = try await ATProtoTools().createReplyReference(from: threadPost2, session: session)","","    let threadPost3 = try await atProtoBluesky.createPostRecord(","        text: \"I also like ice cream.\",","        replyTo: secondReplyReference","    )","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Adding-Audience-Controls","level":1,"type":"heading","text":"Adding Audience Controls"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can control who can reply to your post and whether it can be embedded by other posts."}]},{"anchor":"Controlling-Replies-Threadgate","level":2,"type":"heading","text":"Controlling Replies (Threadgate)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"replyControls"},{"type":"text","text":" parameter to restrict who can reply:"}]},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Only my followers can reply to this post!\",","        replyControls: [.allowFollowers]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can combine multiple rules:","type":"text"}]},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Only people I follow or who follow me can reply.\",","        replyControls: [.allowFollowers, .allowFollowing]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Disabling-Embedding-Postgate","level":2,"type":"heading","text":"Disabling Embedding (Postgate)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"embeddingRules"},{"type":"text","text":" parameter to prevent others from quoting your post:"}]},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"This post cannot be quoted by others.\",","        embeddingRules: [.disable]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can combine both audience controls:","type":"text"}]},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Followers only replies, no quotes allowed.\",","        replyControls: [.allowFollowers],","        embeddingRules: [.disable]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"identifier":{"url":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky\/createPostRecord(text:inlineFacets:locales:replyTo:embed:labels:tags:creationDate:replyControls:embeddingRules:recordKey:shouldValidate:swapCommit:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/ATProtoKit\/documentation\/ATProtoKit","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/atprotokit\/atprotobluesky\/createpostrecord(text:inlinefacets:locales:replyto:embed:labels:tags:creationdate:replycontrols:embeddingrules:recordkey:shouldvalidate:swapcommit:)"]}],"sections":[],"metadata":{"modules":[{"name":"ATProtoKit"}],"extendedModule":"ATProtoKit","role":"symbol","externalID":"s:10ATProtoKit0A7BlueskyC16createPostRecord4text12inlineFacets7locales7replyTo5embed6labels4tags12creationDate0K8Controls14embeddingRules9recordKey14shouldValidate10swapCommitAA17ComAtprotoLexiconO10RepositoryO15StrongReferenceVSS_Say10Foundation3URLV3url_Si13startPositionSi11endPositiontGSgSayAX6LocaleVGAA14AppBskyLexiconO4FeedO0eF0V14ReplyReferenceVSgAC15EmbedIdentifierOSgAS5LabelO20SelfLabelsDefinitionVSgSaySSGSgAX0Q0VSayAC19ThreadgateAllowRuleOGSgSayAC21PostgateEmbeddingRuleOGSgSSSgSbSgA36_tYaKF","roleHeading":"Instance Method","symbolKind":"method","title"