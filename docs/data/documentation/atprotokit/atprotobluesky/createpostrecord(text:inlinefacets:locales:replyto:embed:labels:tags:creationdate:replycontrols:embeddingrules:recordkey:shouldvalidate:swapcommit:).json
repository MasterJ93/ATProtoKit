nDate"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10Foundation4DateV","text":"Date"},{"kind":"text","text":" = Date(), "},{"kind":"externalParam","text":"replyControls"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:10ATProtoKit0A7BlueskyC","text":"ATProtoBluesky","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:10ATProtoKit0A7BlueskyC19ThreadgateAllowRuleO","text":"ThreadgateAllowRule","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky\/ThreadgateAllowRule"},{"kind":"text","text":"]? = nil, "},{"kind":"externalParam","text":"embeddingRules"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:10ATProtoKit0A7BlueskyC","text":"ATProtoBluesky","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:10ATProtoKit0A7BlueskyC21PostgateEmbeddingRuleO","text":"PostgateEmbeddingRule","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky\/PostgateEmbeddingRule"},{"kind":"text","text":"]? = nil, "},{"kind":"externalParam","text":"recordKey"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"shouldValidate"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":"? = true, "},{"kind":"externalParam","text":"swapCommit"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:10ATProtoKit17ComAtprotoLexiconO","text":"ComAtprotoLexicon","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:10ATProtoKit17ComAtprotoLexiconO10RepositoryO","text":"Repository","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Repository"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:10ATProtoKit17ComAtprotoLexiconO10RepositoryO15StrongReferenceV","text":"StrongReference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Repository\/StrongReference"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"text","content":[{"inlineContent":[{"text":"The text that’s directly displayed in the post record. Current limit is","type":"text"},{"text":" ","type":"text"},{"text":"300 characters.","type":"text"}],"type":"paragraph"}]},{"name":"inlineFacets","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of URLs and index range numbers representing inline link facets."},{"type":"text","text":" "},{"type":"text","text":"Optional. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"name":"locales","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The languages the text is written in. Defaults to an empty array."},{"type":"text","text":" "},{"type":"text","text":"Current limit is 3 languages."}]}]},{"name":"replyTo","content":[{"inlineContent":[{"type":"text","text":"The post record that this record is replying to. Optional. Defaults to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"embed","content":[{"type":"paragraph","inlineContent":[{"text":"The embed container attached to the post record. Current items include","type":"text"},{"text":" ","type":"text"},{"text":"images, videos, external links, records, and post records with media. Optional.","type":"text"},{"text":" ","type":"text"},{"text":"Defaults to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]}]},{"name":"labels","content":[{"inlineContent":[{"type":"text","text":"An array of labels made by the user. Optional. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"tags","content":[{"type":"paragraph","inlineContent":[{"text":"An array of tags for the post record. Optional. Defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}]}]},{"name":"creationDate","content":[{"inlineContent":[{"type":"text","text":"The date of the post record. Defaults to "},{"type":"codeVoice","code":"Date.now"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"replyControls","content":[{"type":"paragraph","inlineContent":[{"text":"An array of rules to control who can reply to the post. Optional.","type":"text"},{"text":" ","type":"text"},{"text":"Defaults to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":". When provided, a threadgate record is created for the post.","type":"text"}]}]},{"name":"embeddingRules","content":[{"inlineContent":[{"type":"text","text":"An array of rules to control embedding of the post. Optional."},{"type":"text","text":" "},{"type":"text","text":"Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". When provided, a postgate record is created for the post."}],"type":"paragraph"}]},{"name":"recordKey","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The record key of the collection. Optional. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"name":"shouldValidate","content":[{"type":"paragraph","inlineContent":[{"text":"Indicates whether the record should be validated. Optional.","type":"text"},{"text":" ","type":"text"},{"text":"Defaults to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]}]},{"name":"swapCommit","content":[{"inlineContent":[{"type":"text","text":"Swaps out an operation based on the CID. Optional. Defaults to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"inlineContent":[{"text":"A strong reference, which contains the newly-created record’s URI and CID hash.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"This can be used instead of creating your own method if you wish not to do so.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Creating a Post","level":1,"anchor":"Creating-a-Post"},{"inlineContent":[{"type":"text","text":"After you authenticate into Bluesky, you can create a post by using the "},{"type":"codeVoice","code":"text"},{"type":"text","text":" argument:"}],"type":"paragraph"},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Just tried out the new coffee shop in town ☕️ — highly recommend the cold brew!\"","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If your post is longer than 300 characters, the method will only take the first 300"},{"type":"text","text":" "},{"type":"text","text":"characters, discarding the rest."}],"type":"paragraph"},{"inlineContent":[{"text":"Bluesky will automatically set the language of the post to English, but if you need to","type":"text"},{"text":" ","type":"text"},{"text":"manually set it, you can use the ","type":"text"},{"code":"locales","type":"codeVoice"},{"text":" argument:","type":"text"}],"type":"paragraph"},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Première promenade d'automne 🍂. Les couleurs sont magnifiques cette année!\",","        locales: [Locale(identifier: \"fr_FR\")]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"You can add up to three locales at once; only the first three items will be added as this","type":"text"},{"text":" ","type":"text"},{"text":"is the limit mandated by Bluesky.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"createPostRecord()"},{"type":"text","text":" will automatically look for URLs, hashtags, and @mentions for you."},{"type":"text","text":" "},{"type":"text","text":"However, if you would like to add inline link facets to your account, you can use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"inlineFacets"},{"type":"text","text":" parameter:"}],"type":"paragraph"},{"code":["do {","    let inlineFacet = (URL(string: \"https:\/\/www.loc.gov\/resource\/pga.05046\/\"), 57, 72)","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Where's that weird photo of a cat when you need one?\\n\\nAh: here it is!\",","        inlineFacets: [inlineFacet]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"startPostion"},{"type":"text","text":" and "},{"type":"codeVoice","code":"endPostion"},{"type":"text","text":" must be UTF-8 values."}]}],"name":"Note"},{"type":"heading","text":"Adding Embedded Content","level":1,"anchor":"Adding-Embedded-Content"},{"inlineContent":[{"text":"You can embed various kinds of content in your post, from media to external links,","type":"text"},{"text":" ","type":"text"},{"text":"to other records.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Images","level":2,"anchor":"Images"},{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoTools\/ImageQuery","type":"reference","isActive":true},{"type":"text","text":" to add details to the image, such as"},{"type":"text","text":" "},{"type":"text","text":"alt text, then attach it to the post record."}],"type":"paragraph"},{"code":["do {","    let image = ATProtoTools.ImageQuery(","        imageData: Data(contentsOf: \"\/path\/to\/file\/cat.jpg\"),","        fileName: \"cat.jpg\",","        altText: \"A cat looking annoyed, wearing a hat.\"","    )","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"I don't think my cat likes her new hat... 🙃\",","        embed: .images(","            images: [image]","        )","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Up to four images can be attached to a post. All images need to be a .jpg format."}],"type":"paragraph"},{"type":"heading","text":"Videos","level":2,"anchor":"Videos"},{"inlineContent":[{"text":"Similar to images, you can add videos to a post.","type":"text"}],"type":"paragraph"},{"code":["let videoURL = URL(string: \"\/path\/to\/file\/beach.mp4\")","","do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"The waves on the beach are looking as beautiful as ever.\",","        embed: .video(video: Data(contentsOf: videoFileURL))","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Only one video can be added to a post, can be 100 MB or less, and must use the .mp4 format."},{"type":"text","text":" "},{"type":"text","text":"You can upload up to 25 videos per day and the 25 videos can’t exceed a total of 500 MB"},{"type":"text","text":" "},{"type":"text","text":"for the day."}],"type":"paragraph"},{"style":"tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Bluesky allows you to upload GIFs the same way, as it considers it to be a special kind"},{"type":"text","text":" "},{"type":"text","text":"of video.. The only difference with a GIF is the lack a player scrubber. The same restrictions"},{"type":"text","text":" "},{"type":"text","text":"with respect to videos apply to uploaded GIFs."}],"type":"paragraph"}],"name":"Tip"},{"type":"heading","text":"External Links","level":2,"anchor":"External-Links"},{"inlineContent":[{"type":"text","text":"You can attach a website card to the post."}],"type":"paragraph"},{"code":["Task {","    print(\"Starting application...\")","","    do {","        let session = try await config.authenticate()","","        let externalLinkBuilder = ExternalLinkBuilder()","","        guard let link = URL(string: \"https:\/\/www.youtube.com\/watch?v=dQw4w9WgXcQ\") else { return }","        let metadata = try await linkBuilder.grabMetadata(from: link)","","        let atProto = ATProtoKit(session: session)","        let atProtoBluesky = ATProtoBluesky(atProtoKitInstance: atProto)","","        let postResult = try await atProtoBluesky.createPostRecord(","            text: \"Really glad to hear his talk in person!\",","            embed: .external(","                url: metadata.url,","                title: metadata.title,","                description: metadata.description ?? \"No description given.\",","                thumbnailURL: metadata.thumbnailURL","            )","        )","","        print(\"Post Result: \\(postResult)\")","    } catch {","        throw error","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If there are any links in the post’s text, the method will not convert it into a"},{"text":" ","type":"text"},{"text":"website card; you will need to manually achieve this.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Creating a Quote Post","level":1,"anchor":"Creating-a-Quote-Post"},{"inlineContent":[{"text":"Quote posts are also embeds: you simply need to embed the record’s strong reference to it.","type":"text"}],"type":"paragraph"},{"code":["do {","    let strongReference = ComAtprotoLexicon.Repository.StrongReference(recordURI: record.uri, cidHash: record.cid)","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Me whenever I look at my email:\",","        embed: .record(strongReference: strongReference)","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Only one record can be embedded. This isn’t limited to post records, though: you can embed","type":"text"},{"text":" ","type":"text"},{"text":"any Bluesky-related record that you wish.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Creating a Reply","level":1,"anchor":"Creating-a-Reply"},{"inlineContent":[{"text":"To create a reply, pass the reply reference of the post’s reply reference to the post record.","type":"text"}],"type":"paragraph"},{"code":["do {","    let replyReference = try await ATProtoTools().createReplyReference(","        from: parentPost,","        session: session","    )","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"I also like pancakes.\",","        replyTo: replyReference","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"If you want to create a thread of posts, use","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoTools\/createReplyReference(from:session:)"},{"text":" to create the reply reference and","type":"text"},{"text":" ","type":"text"},{"text":"pass that over to ","type":"text"},{"type":"codeVoice","code":"replyTo"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["do {","    let threadPost = try await atProtoBluesky.createPostRecord(","        text: \"I like waffles.\"","    )","","    print(\"Replying...\")","","    let firstReplyReference = try await ATProtoTools().createReplyReference(from: threadPost, session: session)","","    let threadPost2 = try await atProtoBluesky.createPostRecord(","        text: \"I also like pancakes.\",","        replyTo: firstReplyReference","    )","","    print(\"Second reply...\")","","    let secondReplyReference = try await ATProtoTools().createReplyReference(from: threadPost2, session: session)","","    let threadPost3 = try await atProtoBluesky.createPostRecord(","        text: \"I also like ice cream.\",","        replyTo: secondReplyReference","    )","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Adding Audience Controls","level":1,"anchor":"Adding-Audience-Controls"},{"inlineContent":[{"type":"text","text":"You can control who can reply to your post and whether it can be embedded by other posts."}],"type":"paragraph"},{"type":"heading","text":"Controlling Replies (Threadgate)","level":2,"anchor":"Controlling-Replies-Threadgate"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"replyControls"},{"type":"text","text":" parameter to restrict who can reply:"}],"type":"paragraph"},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Only my followers can reply to this post!\",","        replyControls: [.allowFollowers]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"You can combine multiple rules:","type":"text"}],"type":"paragraph"},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Only people I follow or who follow me can reply.\",","        replyControls: [.allowFollowers, .allowFollowing]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","text":"Disabling Embedding (Postgate)","level":2,"anchor":"Disabling-Embedding-Postgate"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"embeddingRules"},{"type":"text","text":" parameter to prevent others from quoting your post:"}],"type":"paragraph"},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"This post cannot be quoted by others.\",","        embeddingRules: [.disable]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"You can combine both audience controls:"}],"type":"paragraph"},{"code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Followers only replies, no quotes allowed.\",","        replyControls: [.allowFollowers],","        embeddingRules: [.disable]","    )","","    print(postResult)","} catch {","    throw error","}"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/atprotokit\/atprotobluesky\/createpostrecord(text:inlinefacets:locales:replyto:embed:labels:tags:creationdate:replycontrols:embeddingrules:recordkey:shouldvalidate:swapcommit:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/ATProtoKit\/documentation\/ATProtoKit","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoBluesky"]]},"sections":[],"metadata":{"title":"createPostRecord(text:inlineFacets:locales:replyTo:embed:labels:tags:creationDate:replyControls:embeddingRules:recordKey:shouldValidate:swapCommit:)","roleHeading":"Instance Method","modules":[{"name":"ATProtoKit"}],"extendedModule":"ATProtoKit","symbolKind":"method","remoteSource":{"url":"https:\/\/github.com\/MasterJ93\/ATProtoKit\/tree\/main\/Sources\/ATProtoKit\/APIReference\/ATProtoBlueskyAPI\/PostRecord\/CreatePostRecord.swift#L332","fileName":"CreatePostRecord.swift"},"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"cr