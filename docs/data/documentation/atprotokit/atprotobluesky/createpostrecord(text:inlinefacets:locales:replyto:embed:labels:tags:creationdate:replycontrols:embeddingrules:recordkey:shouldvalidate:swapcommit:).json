]},{"name":"labels","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of labels made by the user. Optional. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of tags for the post record. Optional. Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}],"name":"tags"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The date of the post record. Defaults to "},{"type":"codeVoice","code":"Date.now"},{"type":"text","text":"."}]}],"name":"creationDate"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of rules to control who can reply to the post. Optional."},{"type":"text","text":" "},{"type":"text","text":"Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". When provided, a threadgate record is created for the post."}]}],"name":"replyControls"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of rules to control embedding of the post. Optional."},{"type":"text","text":" "},{"type":"text","text":"Defaults to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". When provided, a postgate record is created for the post."}]}],"name":"embeddingRules"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The record key of the collection. Optional. Defaults to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]}],"name":"recordKey"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Indicates whether the record should be validated. Optional.","type":"text"},{"text":" ","type":"text"},{"text":"Defaults to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]}],"name":"shouldValidate"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Swaps out an operation based on the CID. Optional. Defaults to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]}],"name":"swapCommit"}]},{"kind":"content","content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"inlineContent":[{"type":"text","text":"A strong reference, which contains the newly-created record’s URI and CID hash."}],"type":"paragraph"}]},{"kind":"mentions","mentions":["doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATLinkBuilderProtocol","doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/Getting-Started-with-ATProtoKit"]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"This can be used instead of creating your own method if you wish not to do so."}],"type":"paragraph"},{"level":1,"anchor":"Creating-a-Post","type":"heading","text":"Creating a Post"},{"inlineContent":[{"text":"After you authenticate into Bluesky, you can create a post by using the ","type":"text"},{"code":"text","type":"codeVoice"},{"text":" argument:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Just tried out the new coffee shop in town ☕️ — highly recommend the cold brew!\"","    )","","    print(postResult)","} catch {","    throw error","}"]},{"inlineContent":[{"text":"If your post is longer than 300 characters, the method will only take the first 300","type":"text"},{"text":" ","type":"text"},{"text":"characters, discarding the rest.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Bluesky will automatically set the language of the post to English, but if you need to"},{"type":"text","text":" "},{"type":"text","text":"manually set it, you can use the "},{"code":"locales","type":"codeVoice"},{"text":" argument:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Première promenade d'automne 🍂. Les couleurs sont magnifiques cette année!\",","        locales: [Locale(identifier: \"fr_FR\")]","    )","","    print(postResult)","} catch {","    throw error","}"]},{"inlineContent":[{"type":"text","text":"You can add up to three locales at once; only the first three items will be added as this"},{"type":"text","text":" "},{"text":"is the limit mandated by Bluesky.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"createPostRecord()"},{"type":"text","text":" will automatically look for URLs, hashtags, and @mentions for you."},{"type":"text","text":" "},{"type":"text","text":"However, if you would like to add inline link facets to your account, you can use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"inlineFacets"},{"type":"text","text":" parameter:"}]},{"code":["do {","    let inlineFacet = (URL(string: \"https:\/\/www.loc.gov\/resource\/pga.05046\/\"), 57, 72)","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Where's that weird photo of a cat when you need one?\\n\\nAh: here it is!\",","        inlineFacets: [inlineFacet]","    )","","    print(postResult)","} catch {","    throw error","}"],"syntax":"swift","type":"codeListing"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"startPostion"},{"type":"text","text":" and "},{"code":"endPostion","type":"codeVoice"},{"type":"text","text":" must be UTF-8 values."}]}],"style":"note"},{"text":"Adding Embedded Content","anchor":"Adding-Embedded-Content","type":"heading","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can embed various kinds of content in your post, from media to external links,"},{"type":"text","text":" "},{"type":"text","text":"to other records."}]},{"text":"Images","anchor":"Images","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoTools\/ImageQuery"},{"type":"text","text":" to add details to the image, such as"},{"type":"text","text":" "},{"type":"text","text":"alt text, then attach it to the post record."}]},{"syntax":"swift","type":"codeListing","code":["do {","    let image = ATProtoTools.ImageQuery(","        imageData: Data(contentsOf: \"\/path\/to\/file\/cat.jpg\"),","        fileName: \"cat.jpg\",","        altText: \"A cat looking annoyed, wearing a hat.\"","    )","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"I don't think my cat likes her new hat... 🙃\",","        embed: .images(","            images: [image]","        )","    )","","    print(postResult)","} catch {","    throw error","}"]},{"inlineContent":[{"text":"Up to four images can be attached to a post. All images need to be a .jpg format.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Videos","type":"heading","anchor":"Videos"},{"inlineContent":[{"text":"Similar to images, you can add videos to a post.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let videoURL = URL(string: \"\/path\/to\/file\/beach.mp4\")","","do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"The waves on the beach are looking as beautiful as ever.\",","        embed: .video(video: Data(contentsOf: videoFileURL))","    )","","    print(postResult)","} catch {","    throw error","}"]},{"inlineContent":[{"text":"Only one video can be added to a post, can be 100 MB or less, and must use the .mp4 format.","type":"text"},{"text":" ","type":"text"},{"text":"You can upload up to 25 videos per day and the 25 videos can’t exceed a total of 500 MB","type":"text"},{"text":" ","type":"text"},{"text":"for the day.","type":"text"}],"type":"paragraph"},{"style":"tip","type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bluesky allows you to upload GIFs the same way, as it considers it to be a special kind"},{"type":"text","text":" "},{"type":"text","text":"of video.. The only difference with a GIF is the lack a player scrubber. The same restrictions"},{"type":"text","text":" "},{"type":"text","text":"with respect to videos apply to uploaded GIFs."}]}]},{"level":2,"text":"External Links","type":"heading","anchor":"External-Links"},{"inlineContent":[{"text":"You can attach a website card to the post.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Task {","    print(\"Starting application...\")","","    do {","        try await config.authenticate(with: \"example.bsky.social\", password: \"hunter2\")","","        let externalLinkBuilder = ExternalLinkBuilder()","","        guard let link = URL(string: \"https:\/\/www.youtube.com\/watch?v=dQw4w9WgXcQ\") else { return }","        let metadata = try await linkBuilder.grabMetadata(from: link)","","        let atProto = await ATProtoKit(sessionConfiguration: config)","        let atProtoBluesky = ATProtoBluesky(atProtoKitInstance: atProto)","","        let postResult = try await atProtoBluesky.createPostRecord(","            text: \"Really glad to hear his talk in person!\",","            embed: .external(","                url: metadata.url,","                title: metadata.title,","                description: metadata.description ?? \"No description given.\",","                thumbnailURL: metadata.thumbnailURL","            )","        )","","        print(\"Post Result: \\(postResult)\")","    } catch {","        throw error","    }","}"]},{"inlineContent":[{"text":"If there are any links in the post’s text, the method will not convert it into a","type":"text"},{"text":" ","type":"text"},{"text":"website card; you will need to manually achieve this.","type":"text"}],"type":"paragraph"},{"level":1,"text":"Creating a Quote Post","type":"heading","anchor":"Creating-a-Quote-Post"},{"inlineContent":[{"text":"Quote posts are also embeds: you simply need to embed the record’s strong reference to it.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let strongReference = ComAtprotoLexicon.Repository.StrongReference(recordURI: record.uri, cidHash: record.cid)","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Me whenever I look at my email:\",","        embed: .record(strongReference: strongReference)","    )","","    print(postResult)","} catch {","    throw error","}"]},{"inlineContent":[{"text":"Only one record can be embedded. This isn’t limited to post records, though: you can embed","type":"text"},{"text":" ","type":"text"},{"text":"any Bluesky-related record that you wish.","type":"text"}],"type":"paragraph"},{"level":1,"text":"Creating a Reply","type":"heading","anchor":"Creating-a-Reply"},{"inlineContent":[{"text":"To create a reply, pass the reply reference of the post’s reply reference to the post record.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let replyReference = try await ATProtoTools().createReplyReference(","        from: parentPost,","        session: session","    )","","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"I also like pancakes.\",","        replyTo: replyReference","    )","","    print(postResult)","} catch {","    throw error","}"]},{"inlineContent":[{"text":"If you want to create a thread of posts, use","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtoTools\/createReplyReference(from:session:)"},{"text":" to create the reply reference and","type":"text"},{"text":" ","type":"text"},{"text":"pass that over to ","type":"text"},{"code":"replyTo","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let threadPost = try await atProtoBluesky.createPostRecord(","        text: \"I like waffles.\"","    )","","    print(\"Replying...\")","","    let firstReplyReference = try await ATProtoTools().createReplyReference(from: threadPost, session: session)","","    let threadPost2 = try await atProtoBluesky.createPostRecord(","        text: \"I also like pancakes.\",","        replyTo: firstReplyReference","    )","","    print(\"Second reply...\")","","    let secondReplyReference = try await ATProtoTools().createReplyReference(from: threadPost2, session: session)","","    let threadPost3 = try await atProtoBluesky.createPostRecord(","        text: \"I also like ice cream.\",","        replyTo: secondReplyReference","    )","} catch {","    throw error","}"]},{"level":1,"text":"Adding Audience Controls","type":"heading","anchor":"Adding-Audience-Controls"},{"inlineContent":[{"text":"You can control who can reply to your post and whether it can be embedded by other posts.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Controlling Replies (Threadgate)","type":"heading","anchor":"Controlling-Replies-Threadgate"},{"inlineContent":[{"text":"Use the ","type":"text"},{"code":"replyControls","type":"codeVoice"},{"text":" parameter to restrict who can reply:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Only my followers can reply to this post!\",","        replyControls: [.allowFollowers]","    )","","    print(postResult)","} catch {","    throw error","}"]},{"inlineContent":[{"text":"You can combine multiple rules:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Only people I follow or who follow me can reply.\",","        replyControls: [.allowFollowers, .allowFollowing]","    )","","    print(postResult)","} catch {","    throw error","}"]},{"level":2,"text":"Disabling Embedding (Postgate)","type":"heading","anchor":"Disabling-Embedding-Postgate"},{"inlineContent":[{"text":"Use the ","type":"text"},{"code":"embeddingRules","type":"codeVoice"},{"text":" parameter to prevent others from quoting your post:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"This post cannot be quoted by others.\",","        embeddingRules: [.disable]","    )","","    print(postResult)","} catch {","    throw error","}"]},{"inlineContent":[{"text":"You can combine both audience controls:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    let postResult = try await atProtoBluesky.createPostRecord(","        text: \"Followers only replies, no quotes allowed.\",","        replyControls: [.allowFollowers],","        embeddingRules: [.disable]","    )","","    print(postResult)","} catch {","    throw error","}"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/atprotokit\/atprotobluesky\/createpostrecord(text:inlinefacets:locales:replyto:embed:labels:tags:creationdate:replycontrols:embeddingrules:recordkey:shouldvalidate:swapcommit:)"]}],"kind":"symbol","sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"A convenience method to create a post record to the user account in Bluesky.","type":"text"}],"references":{"doc://ATProtoKit/documentation/ATProtoKit/ComAtprotoLexicon/Label":{"title":"ComAtprotoLexicon.Label","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Label"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ComAtprotoLexicon\/Label","abstract":[{"type":"text","text":"A group of lexicons within the "},{"code":"com.atproto.