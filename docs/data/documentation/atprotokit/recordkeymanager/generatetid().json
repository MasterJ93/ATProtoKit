{"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/atprotokit\/recordkeymanager\/generatetid()"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"mutating","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"generateTID","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"A new ","type":"text"},{"code":"tid","type":"codeVoice"},{"text":" Record Key","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"According to the "},{"identifier":"https:\/\/atproto.com\/specs\/record-key#record-key-type-tid","type":"reference","isActive":true},{"type":"text","text":", a "},{"code":"tid","type":"codeVoice"},{"type":"text","text":" Record Key consists of"},{"type":"text","text":" "},{"type":"text","text":"a 64-bit integer, in the big-endian byte order. : "},{"code":"UInt64","type":"codeVoice"},{"type":"text","text":" is encoded in "},{"type":"codeVoice","code":"base32-sortable"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which is a 13 ASCII character that consists of "},{"type":"codeVoice","code":"234567abcdefghijklmnopqrstuvwxyz"},{"type":"text","text":" with no"},{"type":"text","text":" "},{"type":"text","text":"padding. The specification also requires that the number never decreases: it must"},{"type":"text","text":" "},{"type":"text","text":"always increase."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A specific layout for "},{"typ