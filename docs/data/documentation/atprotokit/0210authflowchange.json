) "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"}],"defaultImplementations":1,"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/SessionConfiguration\/authenticate(with:password:)"},"doc://ATProtoKit/documentation/ATProtoKit/AppleSecureKeychain":{"abstract":[{"type":"text","text":"Manages the keychains asociated with the sessions for the AT Protocol."}],"type":"topic","kind":"symbol","fragments":[{"text":"actor","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AppleSecureKeychain","kind":"identifier"}],"navigatorTitle":[{"text":"AppleSecureKeychain","kind":"identifier"}],"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/AppleSecureKeychain","role":"symbol","url":"\/documentation\/atprotokit\/applesecurekeychain","title":"AppleSecureKeychain"},"doc://ATProtoKit/documentation/ATProtoKit/UserSession":{"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UserSession","kind":"identifier"}],"abstract":[{"text":"Represents an authenticated user session within the AT Protocol.","type":"text"}],"role":"symbol","url":"\/documentation\/atprotokit\/usersession","title":"UserSession","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/UserSession","type":"topic","navigatorTitle":[{"text":"UserSession","kind":"identifier"}]},"atprotokit_icon.png":{"type":"image","alt":"A technology icon representing the ATProtoKit framework.","variants":[{"traits":["1x","light"],"url":"\/images\/ATProtoKit\/atprotokit_icon.png"}],"identifier":"atprotokit_icon.png"},"doc://ATProtoKit/documentation/ATProtoKit/ATProtocolConfiguration/refreshSession()":{"kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refreshSession"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"}],"abstract":[],"title":"refresh