"url":"\/documentation\/atprotokit\/atprotokit","abstract":[{"text":"The base class that handles the main functionality of the ","type":"text"},{"code":"ATProtoKit","type":"codeVoice"},{"text":" API library.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"ATProtoKit","kind":"identifier"}]},"doc://ATProtoKit/documentation/ATProtoKit/ATProtocolConfiguration/getSession()":{"abstract":[{"type":"text","text":"Fetches an existing session using an access token."}],"role":"symbol","kind":"symbol","url":"\/documentation\/atprotokit\/atprotocolconfiguration\/getsession()","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration\/getSession()","type":"topic","title":"getSession()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getSession","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"}]},"doc://ATProtoKit/documentation/ATProtoKit":{"title":"ATProtoKit","role":"collection","url":"\/documentation\/atprotokit","type":"topic","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit","images":[{"type":"icon","identifier":"atprotokit_icon.png"}],"kind":"symbol","abstract":[{"text":"Develop and manage client and server-side applications for the AT Protocol and Bluesky.","type":"text"}]},"doc://ATProtoKit/documentation/ATProtoKit/AppleSecureKeychain":{"type":"topic","url":"\/documentation\/atprotokit\/applesecurekeychain","abstract":[{"type":"text","text":"Manages the keychains asociated with the sessions for the AT Protocol."}],"fragments":[{"kind":"keyword","text":"actor"},{"kind":"text","text":" "},{"kind":"identifier","text":"AppleSecureKeychain"}],"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/AppleSecureKeychain","navigatorTitle":[{"kind":"identifier","text":"AppleSecureKeychain"}],"role":"symbol","kind":"symbol","title":"AppleSecureKeychain"},"doc://ATProtoKit/documentation/ATProtoKit/ATProtocolConfiguration/deleteSession()":{"abstract":[{"type":"text","text":"Deletes the user session."}],"role":"symbol","kind":"symbol","url":"\/documentation\/atprotokit\/atprotocolconfiguration\/deletesession()","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration\/deleteSession()","type":"topic","title":"deleteSession()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"deleteSession","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"}]},"doc://ATProtoKit/documentation/ATProtoKit/ATProtocolConfiguration":{"type":"topic","url":"\/documentation\/atprotokit\/atprotocolconfiguration","abstract":[{"type":"text","text":"Manages authentication and session operations for the a user account in the AT Protocol."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ATProtocolConfiguration","kind":"identifier"}],"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration","navigatorTitle":[{"text":"ATProtocolConfiguration","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"ATProtocolConfiguration"},"doc://ATProtoKit/documentation/ATProtoKit/ATProtocolConfiguration/refreshSession()":{"abstract":[{"type":"text","text":"Refreshes the user’s session using a refresh token."}],"role":"symbol","kind":"symbol","url":"\/documentation\/atprotokit\/atprotocolconfiguration\/refreshsession()","identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/ATProtocolConfiguration\/refreshSession()","type":"topic","title":"refreshSession()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"refreshSession","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"}]},"doc://ATProtoKit/documentation/ATProtoKit/SessionConfiguration":{"type":"topic","url":"\/documentation\/atprotokit\/sessionconfiguration","abstract":[{"type":"text","text":"Defines the requirements for session configurations within ATProtoKit."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SessionConfiguration","kind":"identifier"}],"identifier":"doc:\/\/ATProtoKit\/documentation\/ATProtoKit\/SessionConfiguration","navigatorTitle":[{"text":"SessionConfiguration","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"SessionConfiguration"}}}